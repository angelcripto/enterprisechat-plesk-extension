#!/usr/bin/env bash
#
# sbin wrapper invocado vía pm_ApiCli::callSbin('install') desde
# plib/scripts/post-install.php. Plesk lo despliega en
# /usr/local/psa/admin/sbin/modules/enterprisechat/install con setuid root,
# por lo que aquí ya tenemos privilegios para apt-get / systemctl.
#
# Acciones:
#   1. Localiza el .deb en plib/payload/.
#   2. Instala o reinstala el paquete con apt-get.
#   3. Si no existe appsettings.Production.json, genera SigningKey + admin
#      password aleatorios y los escribe.
#   4. Arranca el servicio.
#
set -euo pipefail

# Resolución defensiva del directorio plib del módulo, soportando los dos
# layouts típicos (/opt/psa simlinkado a /usr/local/psa).
SBIN_DIR="$(cd "$(dirname "$0")" && pwd)"
EXT_ID="$(basename "$SBIN_DIR")"

PLIB_DIR=""
for candidate in \
    "/usr/local/psa/admin/plib/modules/$EXT_ID" \
    "/opt/psa/admin/plib/modules/$EXT_ID"; do
    if [[ -d "$candidate" ]]; then
        PLIB_DIR="$candidate"
        break
    fi
done

if [[ -z "$PLIB_DIR" ]]; then
    echo "ERROR: no se localiza plib/ del módulo $EXT_ID" >&2
    exit 1
fi

DEB="$(ls -1 "$PLIB_DIR"/payload/enterprisechat_*_amd64.deb 2>/dev/null | head -n1 || true)"
if [[ -z "$DEB" ]]; then
    echo "ERROR: no se encontró el paquete .deb en $PLIB_DIR/payload/" >&2
    exit 1
fi

INSTALL_DIR=/opt/enterprisechat
SERVICE_USER=enterprisechat
SETTINGS="$INSTALL_DIR/appsettings.Production.json"

# --- 1. Instalar / actualizar paquete --------------------------------------
echo "==> Instalando $DEB"
export DEBIAN_FRONTEND=noninteractive
if dpkg -s enterprisechat >/dev/null 2>&1; then
    apt-get install -y --reinstall --allow-downgrades "$DEB" || dpkg -i "$DEB" || apt-get install -fy
else
    apt-get install -y "$DEB" || { dpkg -i "$DEB"; apt-get install -fy; }
fi

# --- 2. Bootstrap secretos -------------------------------------------------
if [[ ! -f "$SETTINGS" ]]; then
    echo "==> Generando secretos iniciales"
    JWT_KEY="$(openssl rand -base64 48 | tr -d '\n')"
    ADMIN_PWD="$(openssl rand -base64 18 | tr -d '\n=+/' | head -c 16)"

    umask 027
    cat > "$SETTINGS" <<EOF
{
  "EnterpriseChat": {
    "Jwt": {
      "SigningKey": "$JWT_KEY",
      "Issuer": "EnterpriseChat.Prod",
      "Audience": "EnterpriseChat.Clients",
      "AccessTokenLifetimeMinutes": 60
    },
    "Bootstrap": { "AdminPassword": "$ADMIN_PWD" }
  }
}
EOF
    chown "$SERVICE_USER:$SERVICE_USER" "$SETTINGS"
    chmod 0640 "$SETTINGS"

    # Reveal one-shot: la UI Plesk lo muestra una vez y lo borra.
    echo "$ADMIN_PWD" > "$INSTALL_DIR/.first-admin-password"
    chown "$SERVICE_USER:$SERVICE_USER" "$INSTALL_DIR/.first-admin-password"
    chmod 0600 "$INSTALL_DIR/.first-admin-password"
fi

# --- 3. Arrancar -----------------------------------------------------------
systemctl daemon-reload
systemctl enable --now enterprisechat.service
systemctl --no-pager status enterprisechat.service || true

echo "==> EnterpriseChat instalado. Abre el panel Plesk para enlazar dominio."
