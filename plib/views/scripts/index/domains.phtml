<?php /** @var Zend_View $this */ ?>
<p>
    <a href="<?= pm_Context::getBaseUrl() ?>">
        ← <?= $this->escape($this->lmsg('btnBack')) ?>
    </a>
</p>

<h2><?= $this->escape($this->lmsg('bindingsTitle')) ?></h2>

<p>
    <a class="btn btn-primary" href="<?= pm_Context::getActionUrl('index', 'create-subdomain') ?>">
        + <?= $this->escape($this->lmsg('btnCreateSubdomain')) ?>
    </a>
    <a class="btn" href="<?= pm_Context::getActionUrl('index', 'bind-existing') ?>">
        <?= $this->escape($this->lmsg('btnBindExisting')) ?>
    </a>
</p>

<?php if (empty($this->bindings)): ?>
    <p><em><?= $this->escape($this->lmsg('bindingsEmpty')) ?></em></p>
<?php else: ?>
    <table class="list">
        <thead>
            <tr>
                <th><?= $this->escape($this->lmsg('lblDomain')) ?></th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        <?php foreach ($this->bindings as $d): ?>
            <tr>
                <td>
                    <a href="https://<?= $this->escape($d) ?>/" target="_blank" rel="noopener">
                        <?= $this->escape($d) ?>
                    </a>
                </td>
                <td>
                    <form method="post" action="<?= pm_Context::getActionUrl('index', 'unbind') ?>"
                          onsubmit="return confirm('<?= $this->escape($this->lmsg('confirmUnbind')) ?>');"
                          style="display:inline">
                        <input type="hidden" name="domain" value="<?= $this->escape($d) ?>">
                        <button class="btn" type="submit">
                            <?= $this->escape($this->lmsg('btnUnbind')) ?>
                        </button>
                    </form>
                </td>
            </tr>
        <?php endforeach; ?>
        </tbody>
    </table>
<?php endif; ?>
