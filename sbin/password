#!/usr/bin/env bash
#
# Wrapper privilegiado para gestión de contraseñas del admin del chat.
#
# Acciones:
#   consume-first         lee y borra /opt/enterprisechat/.first-admin-password
#                         (Plesk demota el panel a psaadm; ese archivo es 0600
#                         owner=enterprisechat, así que sin este wrapper la UI
#                         nunca podría leerlo).
#   reset-admin <pwd>     ejecuta el server con --reset-admin-password como
#                         el usuario enterprisechat (Sqlite WAL permite que el
#                         servicio principal siga corriendo durante el reset).
#
set -euo pipefail

INSTALL_DIR=/opt/enterprisechat
SERVICE_USER=enterprisechat
FIRST_FILE="$INSTALL_DIR/.first-admin-password"
BINARY="$INSTALL_DIR/EnterpriseChat.Server"

ACTION="${1:-}"

case "$ACTION" in
    consume-first)
        if [[ -f "$FIRST_FILE" ]]; then
            cat "$FIRST_FILE"
            rm -f "$FIRST_FILE"
        fi
        ;;
    reset-admin)
        NEWPWD="${2:-}"
        if [[ -z "$NEWPWD" ]]; then
            echo "password reset-admin: falta nueva contraseña" >&2
            exit 2
        fi
        if [[ ${#NEWPWD} -lt 4 ]]; then
            echo "password reset-admin: la contraseña debe tener 4+ caracteres" >&2
            exit 2
        fi
        if [[ ! -x "$BINARY" ]]; then
            echo "password reset-admin: binario no encontrado en $BINARY" >&2
            exit 1
        fi
        cd "$INSTALL_DIR"
        export ASPNETCORE_ENVIRONMENT=Production
        if command -v sudo >/dev/null 2>&1; then
            sudo -u "$SERVICE_USER" -E "$BINARY" --reset-admin-password "$NEWPWD"
        elif command -v runuser >/dev/null 2>&1; then
            runuser -u "$SERVICE_USER" -- env ASPNETCORE_ENVIRONMENT=Production \
                "$BINARY" --reset-admin-password "$NEWPWD"
        else
            echo "password reset-admin: ni sudo ni runuser disponibles" >&2
            exit 1
        fi
        ;;
    *)
        echo "password: acción desconocida '$ACTION' (consume-first | reset-admin)" >&2
        exit 2
        ;;
esac
