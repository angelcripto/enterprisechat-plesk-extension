#!/usr/bin/env bash
#
# Wrapper privilegiado que gestiona "Additional nginx directives" del dominio
# elegido para enrutar el reverse proxy al servidor EnterpriseChat.
#
# La ruta correcta en Plesk Obsidian es
#   /var/www/vhosts/system/<dominio>/conf/vhost_nginx.conf
# que Plesk incluye DENTRO del bloque `server { }` del vhost al regenerar.
# No usar /etc/nginx/plesk.conf.d/vhosts/*.conf — esos se cargan FUERA del
# bloque server y un `location { }` ahí rompe nginx.
#
# Acciones:
#   write <domain> <base64-content>
#   rm    <domain>
#   list
#
# Restricciones:
#   - <dominio> debe pasar la regex de FQDN.
#   - Se escribe / borra únicamente vhost_nginx.conf y se marca como gestionado
#     por la extensión vía cabecera para detectar conflicto con otro origen.
#
set -euo pipefail

VHOSTS_ROOT=/var/www/vhosts/system
MARK='# Managed by Plesk extension EnterpriseChat — do not edit by hand.'

ACTION="${1:-}"
if [[ -z "$ACTION" ]]; then
    echo "uso: nginx-snippet (write|rm|list) [<domain>] [<base64-content>]" >&2
    exit 2
fi

if [[ "$ACTION" == "list" ]]; then
    shopt -s nullglob
    for f in "$VHOSTS_ROOT"/*/conf/vhost_nginx.conf; do
        if head -n1 "$f" 2>/dev/null | grep -qF "$MARK"; then
            dom="${f#$VHOSTS_ROOT/}"
            dom="${dom%%/*}"
            echo "$dom"
        fi
    done
    exit 0
fi

DOMAIN="${2:-}"
if [[ -z "$DOMAIN" ]]; then
    echo "nginx-snippet: falta dominio para acción '$ACTION'" >&2
    exit 2
fi
if [[ ! "$DOMAIN" =~ ^[a-z0-9]([a-z0-9.\-]*[a-z0-9])?$ ]]; then
    echo "nginx-snippet: dominio inválido: $DOMAIN" >&2
    exit 2
fi

CONF_DIR="$VHOSTS_ROOT/$DOMAIN/conf"
SNIPPET="$CONF_DIR/vhost_nginx.conf"

case "$ACTION" in
    write)
        if [[ ! -d "$CONF_DIR" ]]; then
            echo "nginx-snippet: $CONF_DIR no existe (¿se ha creado el dominio en Plesk?)" >&2
            exit 1
        fi
        CONTENT_B64="${3:-}"
        if [[ -z "$CONTENT_B64" ]]; then
            echo "nginx-snippet write: falta contenido base64" >&2
            exit 2
        fi
        # Si ya existe pero NO es nuestro, no lo pisamos.
        if [[ -f "$SNIPPET" ]] && ! head -n1 "$SNIPPET" | grep -qF "$MARK"; then
            echo "nginx-snippet: $SNIPPET ya existe y no fue creado por esta extensión; abortando para no pisar configuración manual." >&2
            exit 1
        fi
        printf '%s' "$CONTENT_B64" | base64 -d > "$SNIPPET"
        chmod 0644 "$SNIPPET"
        ;;
    rm)
        if [[ -f "$SNIPPET" ]] && head -n1 "$SNIPPET" | grep -qF "$MARK"; then
            rm -f "$SNIPPET"
        fi
        ;;
    *)
        echo "nginx-snippet: acción desconocida '$ACTION'" >&2
        exit 2
        ;;
esac

if command -v plesk >/dev/null 2>&1; then
    plesk sbin httpdmng --reconfigure-domain "$DOMAIN" >/dev/null 2>&1 || true
fi
